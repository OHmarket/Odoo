# ============================================================
# .gitignore — OH Market / Odoo Produccion
# ============================================================
# Convención del repo:
#   - SI versionamos: codigo .py, .md, .docx, CLAUDE.md, configs
#   - NO versionamos: exports de datos, caches, outputs
#   - Los datos viven en Odoo (fuente de verdad). Los .csv/.xlsx
#     locales son snapshots manuales para análisis. Se regeneran
#     re-exportando desde Odoo cuando hagan falta.
# ============================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Entornos virtuales ---
.venv/
venv/
env/
.env
.env.*

# --- Datos: exports manuales y outputs ---
# Si vas a versionar un dataset específico como referencia/test,
# agrega excepción explícita: !ruta/al/archivo.csv
*.csv
*.xlsx
*.xls
*.parquet
*.pkl
*.feather
*.h5
*.hdf5

# --- Output / scratch directories ---
/output/
/outputs/
/tmp/
/cache/
/.cache/
/_tmp/

# --- Precios competencia (caches + reportes generados) ---
/04_analitica/salida_precios_competencia/

# --- IDE / editor ---
.vscode/
.idea/
# Claude Code: config local de la maquina (permisos, overrides). No se versiona.
.claude/settings.local.json
*.swp
*.swo
*~

# --- OS ---
Thumbs.db
.DS_Store
desktop.ini

# --- Secretos / credenciales ---
*.token
*.key
*.pem
credentials.json
secrets.yaml
secrets.yml
